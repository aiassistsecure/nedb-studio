# ── NEDB Studio environment ────────────────────────────────────────────────
# Copy to `.env` and fill in. With NO AiAssist credentials, Studio runs in
# deterministic MOCK MODE (fully usable). With credentials, it uses AiAssist
# as the AI gateway. The API key is ONLY ever read server-side (server.ts /
# src/server) — it is never exposed to the browser.

# AiAssist gateway (AiAssist Secure / AiAS). All AI generation goes through this.
AIASSIST_BASE_URL=https://your-aiassist-host.example.com
AIASSIST_API_KEY=replace_me

# Default generation provider + model. X-AiAssist-Provider is sent on EVERY call.
AIASSIST_DEFAULT_PROVIDER=anthropic
AIASSIST_DEFAULT_MODEL=claude-sonnet-4-6

# Runner (fast scaffold generation)
AIASSIST_RUNNER_PROVIDER=anthropic
AIASSIST_RUNNER_MODEL=claude-sonnet-4-6

# Sentinel (validation / repair / schema-consistency pass)
AIASSIST_SENTINEL_PROVIDER=anthropic
AIASSIST_SENTINEL_MODEL=claude-sonnet-4-6

# PORT      — Express API server port (npm run start / npm run dev:api).
#             nginx / your reverse proxy should point here.
PORT=3129

# VITE_PORT — Vite dev client port (what the browser hits in dev, default 3000).
#             Completely separate from PORT.
# VITE_PORT=3000

# STUDIO_API_URL — full override for the Vite /api proxy target (optional).
# Useful if the API is on a different host entirely.
# STUDIO_API_URL=http://127.0.0.1:3129

# ── NEDB connection (deployment) ───────────────────────────────────────────
# The studio is a CLIENT of a running NEDB server (nedbd). Start one with:
#   pip install nedb-engine && nedbd        # http://127.0.0.1:7070
# Then point the studio at it. The Settings panel can override this at runtime.
NEDB_URL=http://127.0.0.1:7070
# Bearer token — only if you started nedbd with NEDBD_TOKEN set.
NEDBD_TOKEN=

# ── NEDB encryption at rest (v0.5.3+) ──────────────────────────────────────
# Table Master Key: 64-char hex string. If set, nedbd opens all databases with
# AES-256-GCM encryption. The DEK is wrapped by this key and stored in key.enc.
# Key rotation: db.rewrap_key(old_tmk, new_tmk) — no data re-encryption needed.
# NEDB_TMK=
# NEDB_TMK_FILE=/run/secrets/nedb-tmk   # alternative: raw bytes from a file
